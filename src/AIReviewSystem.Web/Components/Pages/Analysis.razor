@page "/analysis"
@rendermode InteractiveServer
@using AIReviewSystem.Application.Abstractions
@using AIReviewSystem.Application.Abstractions.Analysis
@using AIReviewSystem.Application.Abstractions.Repositories
@using AIReviewSystem.Domain.Entities
@using AIReviewSystem.Domain.Enums

<PageTitle>AIReviewSystem | Анализ</PageTitle>

<div class="container-fluid px-0">
    <div class="mb-4">
        <h1 class="display-6 mb-2">Анализ репозитория</h1>
        <p class="text-body-secondary mb-0">Первый рабочий сценарий: укажите локальный Git-репозиторий, запустите анализ и получите список изменённых файлов.</p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                        <div>
                            <h2 class="h5 mb-1">Параметры</h2>
                            <p class="text-body-secondary mb-0">Работает с рабочей директорией, папкой <code>.git</code> или подпапкой внутри репозитория.</p>
                        </div>
                        <span class="badge rounded-pill text-bg-primary-subtle text-primary">@GetSourceBadgeLabel()</span>
                    </div>

                    <label for="repositoryPath" class="form-label">Источник репозитория</label>
                    <select class="form-select form-select-lg mb-3" @bind="selectedSourceKind">
                        <option value="0">Локальный путь</option>
                        <option value="1">Локальная папка</option>
                        <option value="2">Папка с файлами (загрузка на сервер)</option>
                        <option value="3">Git URL (будет добавлен позже)</option>
                    </select>

                    @if (selectedSourceKind == (int)RepositorySourceKind.ZipArchive)
                    {
                        <div class="form-text mt-2">
                            Можно выбрать целую папку с проектом. Все файлы будут загружены на сервер и проанализированы.
                        </div>
                        <div class="mt-3">
                            <InputFile OnChange="OnInputFileChange"
                                       multiple
                                       webkitdirectory
                                       directory
                                       mozdirectory />
                        </div>
                    }
                    else
                    {
                        <input id="repositoryPath"
                               class="form-control form-control-lg"
                               placeholder="C:\\Projects\\MyRepo или https://github.com/owner/repo.git"
                               @bind="repositoryPath"
                               @bind:event="oninput" />

                        <div class="form-text mt-2">
                            В MVP поддерживается получение репозитория из локального пути или локальной папки. Для серверной обработки можно загрузить папку с файлами проекта.
                        </div>
                    }

                    <button class="btn btn-primary btn-lg w-100 mt-4"
                            type="button"
                            @onclick="AnalyzeAsync"
                            disabled="@isAnalyzing">
                        @if (isAnalyzing)
                        {
                            <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                            <span>Анализирую...</span>
                        }
                        else
                        {
                            <span>Начать анализ</span>
                        }
                    </button>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="alert alert-danger mt-4 mb-0" role="alert">
                            @errorMessage
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(resolvedRepositoryPath))
                    {
                        <div class="alert alert-success mt-4 mb-0" role="status">
                            <div class="fw-semibold">Репозиторий найден</div>
                            <div class="small text-break">@resolvedRepositoryPath</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
                        <div>
                            <h2 class="h5 mb-1">Результаты</h2>
                            <p class="text-body-secondary mb-0">Список изменённых файлов с типом изменения и количеством строк.</p>
                        </div>

                        @if (rows.Count > 0)
                        {
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge rounded-pill text-bg-secondary">Файлов: @rows.Count</span>
                                <span class="badge rounded-pill text-bg-success">+@totalLinesAdded</span>
                                <span class="badge rounded-pill text-bg-danger">-@totalLinesDeleted</span>
                            </div>
                        }
                    </div>

                    @if (isAnalyzing)
                    {
                        <div class="text-center py-5 text-body-secondary">
                            <div class="spinner-border text-primary mb-3" role="status" aria-hidden="true"></div>
                            <div>Считываем Git-изменения и считаем строки...</div>
                        </div>
                    }
                    else if (rows.Count == 0)
                    {
                        <div class="border rounded-4 bg-body-tertiary p-4 p-lg-5 text-body-secondary">
                            <h3 class="h6 text-body mb-2">Пока нет данных</h3>
                            <p class="mb-0">Запустите анализ, чтобы увидеть изменённые файлы и сводку по строкам.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th scope="col">Severity</th>
                                        <th scope="col">Diagnostic ID</th>
                                        <th scope="col">Message</th>
                                        <th scope="col">File</th>
                                        <th scope="col">Line</th>
                                        <th scope="col">Column</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var finding in findings)
                                    {
                                        <tr>
                                            <td><span class="badge rounded-pill @GetSeverityBadgeClass(finding.Severity)">@GetSeverityLabel(finding.Severity)</span></td>
                                            <td class="fw-semibold">@finding.RuleId</td>
                                            <td class="text-break">@finding.Message</td>
                                            <td class="text-break">@finding.FilePath</td>
                                            <td>@finding.Line</td>
                                            <td>@(finding.Column ?? 0)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(lastAnalyzedAt))
                        {
                            <div class="small text-body-secondary mt-3">Последнее обновление: @lastAnalyzedAt</div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

